#!/usr/bin/env sh
# Runs before every `git commit`. If it fails, the commit is aborted.
#
# What it does, all via `lint-staged.config.mjs`:
#   - ESLint + Prettier on the staged files only (fast).
#   - `npm run typecheck` (project-wide) only when TS files are staged.
#
# Skip (emergencies only): `git commit --no-verify`. Prefer fixing the issue.

npx lint-staged
