# =============================================================================
# .env.example — template for environment variables.
# =============================================================================
# HOW TO USE:
#   1. Copy this file to `.env` in the same folder:    cp .env.example .env
#   2. Fill in the real values in `.env` (NEVER commit `.env` to git).
#   3. Expo will automatically load `.env` when you run `npx expo start`.
#
# Any variable exposed to the app MUST be prefixed with `EXPO_PUBLIC_`.
# Non-prefixed variables are only available in server/build scripts.
#
# Why the prefix? React Native apps ship ALL their environment variables to
# the user's device in the final bundle. The prefix forces you to deliberately
# mark which vars are safe to expose. Never put secrets (API keys that allow
# writes, admin tokens) in EXPO_PUBLIC_*. Those belong on the server side.
# =============================================================================

# --- Required ---------------------------------------------------------------

# Supabase — public URL and anon key (safe to expose to clients).
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# App environment: "development" | "staging" | "production"
EXPO_PUBLIC_APP_ENV=development

# --- Optional (observability) -----------------------------------------------
# Leave blank in local dev unless you want errors/events landing in shared
# dashboards. The SDKs no-op cleanly when these are unset.

# Sentry DSN — get one at https://sentry.io/. Format:
#   https://<key>@<org>.ingest.sentry.io/<project>
EXPO_PUBLIC_SENTRY_DSN=

# PostHog — get an API key at https://posthog.com/. The host defaults to
# PostHog Cloud (US). Use https://eu.i.posthog.com if you choose the EU region.
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
