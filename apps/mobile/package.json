{
  "name": "@venn/mobile",
  "version": "0.0.1",
  "private": true,
  "description": "Venn mobile app (iOS + Android), built with React Native and Expo.",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "web": "expo start --web",
    "lint": "eslint src --max-warnings=0",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
