# =============================================================================
# .gitignore — files that should never be committed to the repo.
# =============================================================================
# Everything listed here is either:
#   (a) generated automatically (node_modules, build output) — never commit generated files,
#   (b) machine-specific (OS cruft, editor settings) — never commit personal config,
#   (c) a secret (.env files, keys) — NEVER commit secrets to git. Ever.
# =============================================================================

# --- Dependencies (always regenerated by `npm install`) -----------------------
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# --- Build output -------------------------------------------------------------
dist/
build/
out/
.next/
.expo/
.expo-shared/
web-build/

# --- Native build artifacts ---------------------------------------------------
ios/Pods/
ios/build/
ios/DerivedData/
android/.gradle/
android/build/
android/app/build/
android/local.properties
*.keystore
*.jks
!debug.keystore

# --- Testing ------------------------------------------------------------------
coverage/
*.lcov
.nyc_output/

# --- TypeScript incremental compilation ---------------------------------------
*.tsbuildinfo

# --- Logs ---------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Environment variables (SECRETS — NEVER COMMIT) ---------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
# Commit .env.example as a template (no real values) — see docs/SETUP.md

# --- IDE and editor files -----------------------------------------------------
.idea/
*.swp
*.swo
*~
.project
.classpath

# --- OS files -----------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- Expo / EAS ---------------------------------------------------------------
.expo/
dist/
web-build/
expo-env.d.ts

# --- Temporary files ----------------------------------------------------------
*.tmp
*.temp
.cache/
.parcel-cache/

# --- Claude / AI tooling local state (do not commit) --------------------------
.claude/local/
